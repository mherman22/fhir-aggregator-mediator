{
  "name": "fhir-aggregator-mediator",
  "version": "1.0.0",
  "description": "OpenHIM mediator that aggregates FHIR R4 search results from multiple FHIR servers into a single endpoint",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "format": "prettier --write 'src/**/*.js' 'tests/**/*.js'"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "express": "^4.21.0",
    "lru-cache": "^10.4.0",
    "openhim-mediator-utils": "^0.4.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "jest": "^29.7.0",
    "nock": "^13.5.0",
    "prettier": "^3.2.0",
    "supertest": "^6.3.0"
  }
}
