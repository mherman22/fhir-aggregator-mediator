FROM node:22-alpine

WORKDIR /app

# Install dependencies
COPY test-client/package*.json ./
RUN npm ci --only=production

# Copy test client source
COPY test-client/ ./

# Install curl for testing
RUN apk add --no-cache curl jq

# Create wait script
RUN echo '#!/bin/sh' > /app/wait-for-aggregator.sh && \
    echo 'echo "Waiting for FHIR aggregator to be ready..."' >> /app/wait-for-aggregator.sh && \
    echo 'until curl -s $AGGREGATOR_URL/metadata > /dev/null; do echo "Waiting for aggregator..."; sleep 5; done' >> /app/wait-for-aggregator.sh && \
    echo 'echo "Aggregator is ready!"' >> /app/wait-for-aggregator.sh && \
    chmod +x /app/wait-for-aggregator.sh

CMD ["/bin/sh", "-c", "/app/wait-for-aggregator.sh && node test-aggregation.js"]